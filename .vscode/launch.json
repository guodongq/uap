{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Test (Current File)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "showLog": true
    },
    {
      "name": "Debug Test (Current Function)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${fileDirname}",
      "args": ["-test.run", "${selectedText}"],
      "showLog": true
    },
    {
      "name": "Debug Example (fx)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/examples/fx",
      "showLog": true
    },
    {
      "name": "Debug Current Package (main)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${fileDirname}",
      "showLog": true
    }
  ]
}
